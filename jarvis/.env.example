# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Modelo: haiku = rápido/económico | sonnet = más inteligente
JARVIS_MODEL=claude-haiku-4-5-20251001

# Nombre del asistente
JARVIS_NAME=Jarvis

# Pantalla de bienvenida animada (splash) en verde al iniciar el modo interactivo
JARVIS_SPLASH_ENABLED=true

# Frase de bienvenida mostrada en el splash (override con --welcome)
JARVIS_WELCOME_MESSAGE="Sistemas en línea. ¿En qué puedo ayudarte?"

# Frase de despedida al salir (override con --goodbye). {name} = nombre del asistente
JARVIS_GOODBYE_MESSAGE="{name} desconectado. Hasta luego."

# Reconocimiento de voz (requiere: pip install SpeechRecognition pyttsx3 pyaudio)
JARVIS_VOICE_ENABLED=false

# Palabra de activación por voz en modo bandeja (--tray)
# Se escucha continuamente en segundo plano; al detectarse, abre la ventana
# Requiere: pip install SpeechRecognition pyaudio
JARVIS_WAKE_WORD=palmiche

# Archivo de historial
JARVIS_HISTORY_FILE=~/.jarvis_history.json

# Máximo de mensajes en historial de conversación
JARVIS_MAX_HISTORY=50

# Backend del loop agéntico:
#   anthropic  → loop manual con Anthropic SDK (default, sin dependencias extra)
#   adk        → Google ADK + LiteLLM + Claude (auto-switch a Gemini si solo hay GOOGLE_API_KEY)
#   gemini     → Google ADK + Gemini nativo (solo requiere GOOGLE_API_KEY)
JARVIS_BACKEND=anthropic

# Google API Key (para backends 'adk' con Gemini o 'gemini')
# Obtén tu key en: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=tu-google-key-aqui

# Modelo Gemini a usar (cuando JARVIS_BACKEND=gemini o adk con auto-detección Gemini)
# JARVIS_GEMINI_MODEL=gemini-2.0-flash

# Ollama backend (JARVIS_BACKEND=ollama) — modelo local sin internet
# Instala Ollama: https://ollama.ai   luego: ollama pull llama3.2
# JARVIS_OLLAMA_HOST=http://localhost:11434
# JARVIS_OLLAMA_MODEL=llama3.2
