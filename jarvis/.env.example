# ============================================================================
# Palmiche J.A.R.V.I.S. — Variables de entorno
# ============================================================================
# Copia este archivo a jarvis/.env y ajusta los valores según tu entorno.
# Las variables comentadas (#) muestran su valor por defecto.

# ---------------------------------------------------------------------------
# API Keys y autenticación
# ---------------------------------------------------------------------------

# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google API Key (para backends 'adk' con Gemini o 'gemini')
# Obtén tu key en: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=tu-google-key-aqui

# ---------------------------------------------------------------------------
# Backend y modelo
# ---------------------------------------------------------------------------

# Backend del loop agéntico:
#   anthropic  → loop manual con Anthropic SDK (default, sin dependencias extra)
#   adk        → Google ADK + LiteLLM + Claude (auto-switch a Gemini si solo hay GOOGLE_API_KEY)
#   gemini     → Google ADK + Gemini nativo (solo requiere GOOGLE_API_KEY)
JARVIS_BACKEND=anthropic

# Modelo: haiku = rápido/económico | sonnet = más inteligente
JARVIS_MODEL=claude-haiku-4-5-20251001

# Modelo Gemini a usar (cuando JARVIS_BACKEND=gemini o adk con auto-detección Gemini)
# JARVIS_GEMINI_MODEL=gemini-2.0-flash

# Ollama backend (JARVIS_BACKEND=ollama) — modelo local sin internet
# Instala Ollama: https://ollama.ai   luego: ollama pull llama3.2
# JARVIS_OLLAMA_HOST=http://localhost:11434
# JARVIS_OLLAMA_MODEL=llama3.2

# Idioma de las skills/tools y del system prompt interno que cada brain
# (anthropic, adk, gemini, ollama) envía a su modelo:
#   en  → schemas de herramientas e instrucciones en inglés (default; mejora la
#         fiabilidad del tool-calling en la mayoría de modelos)
#   es  → mantiene el español original
# Solo afecta lo que el modelo ve internamente: el asistente sigue respondiendo
# al usuario en el idioma del usuario.
# JARVIS_TOOL_LANG=en

# ---------------------------------------------------------------------------
# Asistente e interfaz
# ---------------------------------------------------------------------------

# Nombre del asistente
JARVIS_NAME=Jarvis

# Pantalla de bienvenida animada (splash) en verde al iniciar el modo interactivo
JARVIS_SPLASH_ENABLED=true

# Frase de bienvenida mostrada en el splash (override con --welcome)
JARVIS_WELCOME_MESSAGE="Sistemas en línea. ¿En qué puedo ayudarte?"

# Frase de despedida al salir (override con --goodbye). {name} = nombre del asistente
JARVIS_GOODBYE_MESSAGE="{name} desconectado. Hasta luego."

# Ícono de la bandeja del sistema. Vacío = ícono integrado (cabeza de caballo,
# homenaje a Palmiche). Apunta a tu propia imagen PNG/ICO si quieres otra.
# JARVIS_TRAY_ICON=~/mis_imagenes/palmiche.png

# ---------------------------------------------------------------------------
# Voz y reconocimiento
# ---------------------------------------------------------------------------

# Reconocimiento de voz (requiere: pip install "palmiche-jarvis[voice]")
JARVIS_VOICE_ENABLED=false

# Palabra de activación por voz en modo bandeja (--tray)
# Se escucha continuamente en segundo plano; al detectarse, abre la ventana
# Requiere: pip install SpeechRecognition pyaudio
JARVIS_WAKE_WORD=palmiche

# ---------------------------------------------------------------------------
# Motor de audio (AudioEngine)
# ---------------------------------------------------------------------------

# Volumen de reproducción de audio (0-100). Aplica a TTS y archivos de audio.
JARVIS_AUDIO_VOLUME=100

# Cache de audio TTS: almacena los MP3 generados para evitar re-sintetizar
# frases repetidas. Los archivos se guardan en $TMPDIR/jarvis_tts_cache/.
JARVIS_TTS_CACHE=true

# Streaming por oraciones: divide textos largos (>120 chars) en oraciones
# individuales y las reproduce secuencialmente, reduciendo la latencia percibida.
JARVIS_TTS_STREAM=true

# Archivo MP3/WAV reproducido una vez al iniciar la bandeja del sistema.
# Por defecto usa jarvis/assets/welcome.mp3 si existe. Vacío = sin audio.
# Genera el archivo por defecto con: python extract_assets.py
# JARVIS_WELCOME_AUDIO=jarvis/assets/welcome.mp3

# ---------------------------------------------------------------------------
# Almacenamiento
# ---------------------------------------------------------------------------

# Archivo de historial de conversación
JARVIS_HISTORY_FILE=~/.jarvis_history.json

# Máximo de mensajes en historial de conversación
JARVIS_MAX_HISTORY=50

# Archivo del calendario local de eventos
JARVIS_EVENTS_FILE=~/.jarvis_events.json

# Archivo de notas personales
# JARVIS_NOTES_FILE=~/.jarvis_notes.json

# Herramientas personalizadas en texto plano (sin escribir Python).
# Define tus propias tools mapeadas a comandos de shell. Ver el formato y
# ejemplos en jarvis/custom_tools.example.txt. Si el archivo no existe, no se
# cargan tools personalizadas. Disponibles en todos los backends.
# JARVIS_CUSTOM_TOOLS_FILE=~/.jarvis_custom_tools.txt

# ---------------------------------------------------------------------------
# A2A — Agent-to-Agent protocol (Google spec)
# ---------------------------------------------------------------------------

# Host y puerto del servidor A2A (modo --serve-a2a). 0.0.0.0 escucha en todas
# las interfaces.
# JARVIS_A2A_HOST=0.0.0.0
# JARVIS_A2A_PORT=8080

# Agentes A2A remotos a conectar como herramientas (separados por coma).
# El agente local puede delegar tareas a estos agentes.
# JARVIS_A2A_AGENTS=http://agent1:8080,http://agent2:9090

# ---------------------------------------------------------------------------
# MCP — Model Context Protocol
# ---------------------------------------------------------------------------

# Servidores MCP a conectar como clientes (separados por punto y coma).
# Cada spec puede ser:
#   - Comando stdio: "npx -y @modelcontextprotocol/server-filesystem /tmp"
#   - URL SSE:       "http://localhost:3000"
# JARVIS_MCP_SERVERS=npx -y @modelcontextprotocol/server-filesystem /tmp;http://localhost:3001

# ---------------------------------------------------------------------------
# Computer Use — automatización visual con Gemini (browser o escritorio)
# ---------------------------------------------------------------------------

# Modelo Gemini para computer use (requiere google-genai y GOOGLE_API_KEY)
# COMPUTER_USE_MODEL=gemini-2.5-flash

# Backend: "playwright" (navegador Chromium) o "desktop" (escritorio completo)
# COMPUTER_USE_BACKEND=playwright

# Límite de iteraciones del agente visual por tarea
# COMPUTER_USE_MAX_ITERATIONS=30

# ---------------------------------------------------------------------------
# Logging — registro de ejecución de herramientas
# ---------------------------------------------------------------------------

# Archivo donde se registran las llamadas a herramientas (timestamp, inputs, resultado)
# JARVIS_LOG_FILE=~/.jarvis_tools.log

# Activar/desactivar el logging de herramientas
# JARVIS_LOG_ENABLED=true

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------

# Contraseña sudo para comandos con privilegios (opcional).
# Cuando está configurada, los comandos que requieren sudo reciben la contraseña
# automáticamente via stdin (sudo -S). El agente pide confirmación antes de usarla.
# JARVIS_SUDO_PASSWORD=
